# ═══════════════════════════════════════════════════════
# RegInspector — Production Environment
# ═══════════════════════════════════════════════════════
# Copy to .env.production and fill in secrets.
# Or run: ./scripts/generate-env.sh
# ═══════════════════════════════════════════════════════

# ── PostgreSQL ─────────────────────────────────────
POSTGRES_USER=reginspector
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=reginspector
DATABASE_URL=postgresql+asyncpg://reginspector:CHANGE_ME_STRONG_PASSWORD@postgres:5432/reginspector
DATABASE_URL_SYNC=postgresql://reginspector:CHANGE_ME_STRONG_PASSWORD@postgres:5432/reginspector

# ── Redis ──────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Qdrant ─────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=regulations

# ── Ollama (GPU LLM) ──────────────────────────────
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
OLLAMA_MODEL=qwen2.5:72b

# ── Claude API ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
LLM_PROVIDER=claude
LLM_MODEL=claude-sonnet-4-20250514

# ── Embedding ─────────────────────────────────────
EMBEDDING_MODEL=intfloat/multilingual-e5-large

# ── Auth ───────────────────────────────────────────
SECRET_KEY=CHANGE_ME_64_CHAR_RANDOM_STRING
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── App ────────────────────────────────────────────
DEBUG=false
APP_NAME=RegInspector
CORS_ORIGINS=https://YOUR_VM_IP
